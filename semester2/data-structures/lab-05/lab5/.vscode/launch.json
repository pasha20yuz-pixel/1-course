{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug AVL (input.txt)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/avl_prog.exe",
            "args": ["input.txt"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build-avl"
        },
        {
            "name": "Debug RB (input.txt)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/rb_prog.exe",
            "args": ["input.txt"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build-rb"
        }
    ]
}